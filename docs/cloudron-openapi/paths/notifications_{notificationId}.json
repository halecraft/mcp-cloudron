{
  "get": {
    "operationId": "getNotification",
    "summary": "Get Notification",
    "description": "Get notification by ID",
    "tags": [
      "Notifications"
    ],
    "security": [
      {
        "bearer_auth": [
          "read"
        ]
      },
      {
        "query_auth": [
          "read"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/notificationId.json"
      }
    ],
    "responses": {
      "200": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/Notification.json"
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "404": {
        "$ref": "../components/responses/not_found.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/notifications_{notificationId}/get.sh"
        }
      }
    ]
  },
  "post": {
    "operationId": "updateNotification",
    "summary": "Update Notification",
    "description": "Set notification acknowledged state. Unacknowledged notifications count appears in the navbar of the Dashboard.\n",
    "tags": [
      "Notifications"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/notificationId.json"
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "acknowledged": {
                "type": "boolean",
                "example": true,
                "description": "Set notification to acknowledged or not"
              }
            },
            "required": [
              "acknowledged"
            ]
          }
        }
      }
    },
    "responses": {
      "204": {
        "$ref": "../components/responses/no_content.json"
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "404": {
        "$ref": "../components/responses/not_found.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/notifications_{notificationId}/post.sh"
        }
      }
    ]
  }
}