    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "aliases": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "domain": {
                      "type": "string"
                    }
                  }
                },
                "example": [
                  {
                    "name": "MailboxAlias",
                    "domain": "your.mail.domain.com"
                  }
                ],
                "description": "Array of object including 'name' and 'domain'."
              }
            },
            "required": [
