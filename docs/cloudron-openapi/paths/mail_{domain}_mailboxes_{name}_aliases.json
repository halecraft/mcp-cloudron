{
  "get": {
    "operationId": "getMailboxAliases",
    "summary": "Get mailbox aliases",
    "description": "Get mailbox aliases",
    "tags": [
      "Mail"
    ],
    "security": [
      {
        "bearer_auth": [
          "read"
        ]
      },
      {
        "query_auth": [
          "read"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/parameters-domain.json"
      },
      {
        "$ref": "../components/parameters/name.json"
      }
    ],
    "responses": {
      "200": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "aliases": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "domain": {
                        "type": "string"
                      }
                    }
                  },
                  "example": [
                    {
                      "name": "MailboxAlias",
                      "domain": "your.mail.domain.com"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "404": {
        "$ref": "../components/responses/not_found.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/mail_{domain}_mailboxes_{name}_aliases/get.sh"
        }
      }
    ]
  },
  "put": {
    "operationId": "setAliasesByName",
    "summary": "Set aliases",
    "description": "Set aliases",
