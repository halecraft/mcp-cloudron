{
  "get": {
    "summary": "Download a specific backup for an app",
    "operationId": "downloadBackup",
    "description": "Update a backup for an app.",
    "tags": [
      "Apps"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/appId.json"
      },
      {
        "$ref": "../components/parameters/backupId.json"
      }
    ],
    "responses": {
      "200": {
        "description": "Successful download of the backup",
        "content": {
          "application/octet-stream": {
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/apps_{appId}_backups_{backupId}_download/get.sh"
        }
      }
    ]
  }
}