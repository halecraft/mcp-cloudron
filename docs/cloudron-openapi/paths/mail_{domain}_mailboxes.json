{
  "get": {
    "operationId": "getMailboxes",
    "summary": "List mailboxes",
    "description": "List mailboxes",
    "tags": [
      "Mail"
    ],
    "security": [
      {
        "bearer_auth": [
          "read"
        ]
      },
      {
        "query_auth": [
          "read"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/parameters-domain.json"
      }
    ],
    "responses": {
      "200": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "mailboxes": {
                  "type": "array",
                  "items": {
                    "$ref": "../components/schemas/MailboxList.json"
                  }
                }
              }
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "404": {
        "$ref": "../components/responses/not_found.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/mail_{domain}_mailboxes/get.sh"
        }
      }
    ]
  },
  "post": {
    "operationId": "addMailbox",
    "summary": "Add mailbox",
    "description": "Add mailbox",
    "tags": [
      "Mail"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/parameters-domain.json"
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "name": {
                "type": "string",
                "example": "public",
                "description": "Name of the mailbox."
              },
              "ownerId": {
                "type": "string",
                "example": "uid-92c322b8-c4d7-440b-a34a-54a6428233b6",
                "description": "User Id of the owner."
              },
              "ownerType": {
                "type": "string",
                "example": "user",
                "description": "Role of the user."
              },
              "active": {
                "type": "boolean",
                "example": true,
                "description": "Status of the user."
              },
              "enablePop3": {
                "type": "boolean",
                "example": false,
                "description": "Enable POP3 access for the mailbox."
              },
              "storageQuota": {
                "type": "number",
                "example": 0,
                "description": "Limitation of the storage for the mailbox. Limitation in Bytes."
              },
              "messagesQuota": {
                "type": "number",
                "example": 0,
                "description": "Limitation of saved messages inside the mailbox. Limitation in Bytes."
              }
            },
            "required": [
              "name",
              "ownerId",
              "ownerType",
              "enablePop3",
              "active"
            ]
          }
        }
      }
    },
    "responses": {
      "201": {
        "$ref": "../components/responses/no_content.json"
      },
      "400": {
        "$ref": "../components/responses/bad_field.json"
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/mail_{domain}_mailboxes/post.sh"
        }
      }
    ]
  }
}