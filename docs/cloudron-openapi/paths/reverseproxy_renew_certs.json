{
  "post": {
    "operationId": "renewCerts",
    "summary": "Renew Certs",
    "description": "Trigger manual renewal of Let's encrypt certificates. Note that certs are automatically renewed by Cloudron, 1 month before their expiry.",
    "tags": [
      "Reverse Proxy"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "requestBody": {
      "required": false,
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "rebuild": {
                "type": "boolean",
                "description": "When set all the nginx configurations are regenerated.",
                "default": false
              }
            }
          }
        }
      }
    },
    "responses": {
      "202": {
        "$ref": "../components/responses/task_started.json"
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/reverseproxy_renew_certs/post.sh"
        }
      }
    ]
  }
}