{
  "post": {
    "operationId": "sendInviteEmail",
    "summary": "Send invite email",
    "description": "Send invite email.\nThe role 'user-manager' is required to make this api call.\n",
    "tags": [
      "Users"
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/parameters-userId.json"
      }
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "requestBody": {
