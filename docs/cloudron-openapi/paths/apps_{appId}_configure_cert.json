{
  "post": {
    "operationId": "setCertificate",
    "summary": "Set certificate",
    "description": "Set a certificate for an app.",
    "tags": [
      "Apps"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/appId.json"
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "subdomain": {
                "$ref": "../components/schemas/subdomain.json"
              },
              "domain": {
                "$ref": "../components/schemas/domain.json"
              },
              "key": {
                "type": "string",
                "example": "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASC...\n-----END PRIVATE KEY-----",
                "description": "The private key for the SSL certificate in PEM format."
              },
              "cert": {
                "type": "string",
                "example": "-----BEGIN CERTIFICATE-----\nMIIDXTCCAkWgAwIBAgIJAKK5yMdlWzmMA0G...\n-----END CERTIFICATE-----",
                "description": "The SSL certificate in PEM format."
              }
            },
            "required": [
              "domain",
              "key",
              "cert"
            ]
          }
        }
      }
    },
    "responses": {
      "202": {
        "description": "Accepted",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/task_info.json"
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/apps_{appId}_configure_cert/post.sh"
        }
      }
    ]
  }
}