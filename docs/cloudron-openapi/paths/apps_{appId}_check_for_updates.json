{
  "post": {
    "operationId": "checkForAppUpdates",
    "summary": "Check updates",
    "description": "Check for availabe updates for the app.",
    "tags": [
      "Apps"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/appId.json"
      }
    ],
    "responses": {
      "200": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "updates": {
                  "type": "object",
                  "description": "If the object is empty, there are no available updates.",
                  "example": {}
                }
              }
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/apps_{appId}_check_for_updates/post.sh"
        }
      }
    ]
  }
}