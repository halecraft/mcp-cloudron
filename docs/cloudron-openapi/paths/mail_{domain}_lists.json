{
  "get": {
    "operationId": "getMailDomainLists",
    "summary": "List mail domain lists",
    "description": "List mail domain lists",
    "tags": [
      "Mail"
    ],
    "security": [
      {
        "bearer_auth": [
          "read"
        ]
      },
      {
        "query_auth": [
          "read"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/parameters-domain.json"
      },
      {
        "$ref": "../components/parameters/PaginationPage.json"
      },
      {
        "$ref": "../components/parameters/PaginationPerPage.json"
      },
      {
        "name": "search",
        "in": "query",
        "description": "Filter by lists which match either username or email.",
        "required": false,
        "schema": {
          "type": "string"
        }
      }
    ],
    "responses": {
      "200": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "lists": {
                  "type": "array",
                  "items": {
                    "$ref": "../components/schemas/List.json"
                  }
                }
              }
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "404": {
        "$ref": "../components/responses/not_found.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/mail_{domain}_lists/get.sh"
        }
      }
    ]
  },
  "post": {
    "operationId": "addList",
    "summary": "Add mail domain list",
    "description": "Add a mail domain list.",
    "tags": [
      "Mail"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/parameters-domain.json"
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the list.",
                "example": "private list"
              },
              "membersOnly": {
                "type": "boolean",
                "description": "Set for members only.",
                "example": false
              },
              "active": {
                "type": "boolean",
                "description": "Set list active.",
                "example": false
              },
              "members": {
                "type": "array",
                "description": "Members of the list.",
                "items": {
                  "type": "string"
                },
                "example": [
                  "user@example.com",
                  "user2@example.com"
                ]
              }
            }
          }
        }
      }
    },
    "responses": {
      "201": {
        "$ref": "../components/responses/created.json"
      },
      "400": {
        "$ref": "../components/responses/bad_field.json"
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/mail_{domain}_lists/post.sh"
        }
      }
    ]
  }
}