{
  "get": {
    "operationId": "getAppIcon",
    "summary": "Get app icon",
    "description": "Get app icon.",
    "tags": [
      "Apps"
    ],
    "security": [
      {
        "bearer_auth": [
          "read"
        ]
      },
      {
        "query_auth": [
          "read"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/appId.json"
      }
    ],
    "responses": {
      "200": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "icon": {
                  "type": "string",
                  "description": "This can be an icon, png, jpeg depending on the upstream site. When a custom icon is set, this is the icon which was previously uploaded.",
                  "example": "< base64 encoded image >"
                }
              }
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/apps_{appId}_icon/get.sh"
        }
      }
    ]
  }
}