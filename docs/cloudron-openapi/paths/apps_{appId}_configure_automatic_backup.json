{
  "post": {
    "operationId": "setAutomaticAppBackup",
    "summary": "Set automatic backup",
    "description": "Set whether the app should have automatic backups or not.",
    "tags": [
      "Apps"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/appId.json"
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "enable": {
                "type": "boolean",
                "example": true,
                "description": "Enable for automatic backups of the app, disable if manual backups are preferred."
              }
            }
          }
        }
      }
    },
    "responses": {
      "200": {
        "$ref": "../components/responses/no_content.json"
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/apps_{appId}_configure_automatic_backup/post.sh"
        }
      }
    ]
  }
}