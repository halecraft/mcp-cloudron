{
  "post": {
    "operationId": "createExec",
    "summary": "Create exec",
    "description": "Create app exec.",
    "tags": [
      "Apps"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/appId.json"
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "cmd": {
                "description": "Array of command strings to be executed in sequence.",
                "type": "array",
                "items": {
                  "type": "string",
                  "description": "Command to be executed.",
                  "example": "/bin/bash"
                }
              },
              "tty": {
                "type": "boolean",
                "description": "Indicates whether a TTY should be allocated.",
                "example": true
              },
              "lang": {
                "type": "string",
                "description": "Language setting for the environment.",
                "example": "en_US.UTF-8"
              }
            }
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "c5a5db16-30c4-4202-bfdd-f5bdad6297888"
                }
              }
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/unauthorized.json"
      },
      "403": {
        "$ref": "../components/responses/forbidden.json"
      },
      "500": {
        "$ref": "../components/responses/server_error.json"
      }
    },
    "x-codeSamples": [
      {
        "lang": "cURL",
        "source": {
          "$ref": "../code_samples/cURL/apps_{appId}_exec/post.sh"
        }
      }
    ]
  }
}