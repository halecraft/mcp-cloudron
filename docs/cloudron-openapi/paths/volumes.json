        "source": {
          "$ref": "../code_samples/cURL(EXT4)/volumes/postundefined"
        }
      },
      {
        "lang": "cURL (XFS)",
        "source": {
          "$ref": "../code_samples/cURL(XFS)/volumes/postundefined"
        }
      },
      {
        "lang": "cURL (SSHFS)",
        "source": {
          "$ref": "../code_samples/cURL(SSHFS)/volumes/postundefined"
        }
      },
