{
  "post": {
    "operationId": "impersonateUser",
    "summary": "Impersonate a user",
    "description": "Impersonate a user.\nYou require the 'admin' role to use that call.\n",
    "tags": [
      "Users"
    ],
    "security": [
      {
        "bearer_auth": [
          "write"
        ]
      },
      {
        "query_auth": [
          "write"
        ]
      }
    ],
    "parameters": [
      {
        "$ref": "../components/parameters/parameters-userId.json"
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "properties": {
              "password": {
                "type": "string",
                "description": "Temporary password"
              },
              "expiresAt": {
                "type": "integer",
                "default": "6 * 60 * 60 * 1000; // 6 hours",
                "description": "Time until password expires in miliseconds.",
                "example": 1725615073184
              }
            },
            "required": [
              "password"
            ]
          }
        }
      }
    },
    "responses": {
