{
  "description": "Service information for SFTP service.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "example": "sftp"
    },
    "status": {
      "type": "string",
      "example": "active"
    },
    "memoryUsed": {
      "type": "integer",
      "example": 53608448
    },
    "memoryPercent": {
      "type": "integer",
      "example": 19
    },
    "error": {
      "type": [
        "string",
        "null"
      ],
      "example": null
    },
    "healthcheck": {
      "type": "object",
      "example": null
    },
    "config": {
      "type": "object",
      "example": {
        "requireAdmin": true,
        "memoryLimit": 268435456
      }
    },
    "defaultMemoryLimit": {
      "type": "integer",
      "example": 268435456
    }
  }
}