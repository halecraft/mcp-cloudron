{
  "description": "Service information for Nginx service.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "example": "nginx"
    },
    "status": {
      "type": "string",
      "example": "active"
    },
    "error": {
      "type": [
        "string",
        "null"
      ],
      "example": null
    },
    "healthcheck": {
      "type": "object",
      "example": null
    },
    "config": {
      "type": "object",
      "example": {}
    },
    "defaultMemoryLimit": {
      "type": "integer",
      "example": 0
    }
  }
}