{
	"name": "@halecraft/mcp-cloudron",
	"version": "0.1.1",
	"description": "MCP server for Cloudron instance management - list apps, get status, and manage your self-hosted applications",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"mcp-cloudron": "dist/server.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"start": "node dist/server.js",
		"dev": "tsx watch src/index.ts",
		"test": "vitest run --project unit",
		"test:watch": "vitest --project unit",
		"test:coverage": "vitest run --coverage",
		"test:integration": "dotenv -- vitest run --project integration",
		"verify": "node scripts/verify.mjs",
		"verify:format": "biome check --write --error-on-warnings .",
		"verify:logic": "NO_COLOR=1 vitest run --project unit",
		"verify:types": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
		"lint": "tsc --noEmit",
		"clean": "rm -rf dist",
		"prepublishOnly": "pnpm run build"
	},
	"keywords": [
		"mcp",
		"cloudron",
		"model-context-protocol",
		"ai",
		"automation",
		"self-hosted",
		"server-management",
		"claude",
		"anthropic"
	],
	"authors": [
		"Serenichron <vlad@serenichron.com>",
		"Duane Johnson <duane.johnson@gmail.com>"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/halecraft/mcp-cloudron.git"
	},
	"bugs": {
		"url": "https://github.com/halecraft/mcp-cloudron/issues"
	},
	"homepage": "https://github.com/halecraft/mcp-cloudron#readme",
	"engines": {
		"node": ">=18.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/node": "^24.10.2",
		"dotenv-cli": "^11.0.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.24.3"
	},
	"pnpm": {
		"overrides": {
			"test-exclude": "^7.0.1"
		}
	}
}
